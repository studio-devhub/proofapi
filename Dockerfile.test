# Dockerfile.test — runs all tests inside container
FROM golang:1.22.2-alpine

WORKDIR /app

RUN apk add --no-cache git

COPY go.mod go.sum ./
COPY vendor-local/ ./vendor-local/

RUN GONOSUMDB="*" GOFLAGS="-mod=mod" GOPROXY="direct" go mod download

COPY . .

CMD ["sh", "-c", \
  "GONOSUMDB=* GOFLAGS=-mod=mod go test ./... -v -coverprofile=coverage.out 2>&1 && \
   go tool cover -func=coverage.out"]
