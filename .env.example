# LanguageTool Backend — Environment Variables
# Copy this file: cp .env.example .env

# ── API ──────────────────────────────────────────────────
PORT=4003
API_KEY=change-this-to-a-strong-secret-key

# ── Domain & SSL (production only) ───────────────────────
# DOMAIN=api.yourdomain.com
# SSL_CERT=/etc/ssl/certs/yourdomain.crt
# SSL_KEY=/etc/ssl/private/yourdomain.key

# ── Redis ────────────────────────────────────────────────
REDIS_PASSWORD=change-this-redis-password

# Optional — override only if not using Docker Compose
# REDIS_HOST=redis
# REDIS_PORT=6379

# ── WebSocket CORS ───────────────────────────────────────
# Comma-separated allowed origins for WebSocket connections.
# Leave empty to allow all origins (dev). Set in production.
# ALLOWED_ORIGINS=https://yourapp.com,https://app.yourapp.com

# ── LanguageTool ─────────────────────────────────────────
# Managed by docker-compose, no need to change
# LT_URL=http://languagetool:8010
